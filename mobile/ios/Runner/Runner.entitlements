<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<!-- APNs environment for FCM. Xcode flips this to "production" for
		     release/TestFlight automatically when the Push Notifications
		     capability is enabled on the Runner target. -->
		<key>aps-environment</key>
		<string>development</string>
	</dict>
</plist>
