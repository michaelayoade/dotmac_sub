# Core database/runtime (adjust to your environment)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/dotmac_sub
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
POSTGRES_PASSWORD=change-me

# Redis/cache
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@localhost:6379/0
SESSION_REDIS_URL=redis://:change-me@localhost:6379/0
CELERY_BROKER_URL=redis://:change-me@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:change-me@localhost:6379/1

# Private S3-compatible object storage (MinIO local default)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=dotmac-private
S3_REGION=us-east-1

# Migration scripts (SmartOLT + Splynx) — only needed during migration
# SMARTOLT_API_KEY=your-smartolt-api-key
# SPLYNX_MYSQL_PASS=your-splynx-mysql-password
# SPLYNX_MYSQL_PASSWORD=your-splynx-mysql-password
# GENIEACS_NBI_URL=http://localhost:7557

# Monitoring
# Leave blank to disable GlitchTip/Sentry export in environments without egress.
GLITCHTIP_DSN=

# Credential encryption (Fernet key for encrypting NAS/PPPoE passwords at rest)
# CREDENTIAL_ENCRYPTION_KEY=generate-with-make-generate-encryption-key
