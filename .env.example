# Core database/runtime (Compose defaults to the local dotmac-db service)
APP_ENV=production
SERVER_NAME=dotmac-sub-prod
APP_URL=https://selfcare.dotmac.io
DATABASE_URL=postgresql+psycopg://postgres:change-me@dotmac-db:5432/dotmac_sub
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
POSTGRES_PASSWORD=change-me
PG_LOCAL_BOOTSTRAP_PASSWORD=change-me
POSTGRES_IMAGE=dotmac/postgis-pgbackrest:16-3.4-2.51

# Database recovery. Deploys verify backup freshness; they never create a full
# dump on the request path. bootstrap_pgbackrest.sh creates the encryption key
# once in OpenBao and renders only a root/postgres-readable runtime config.
BACKUP_MODE=pgbackrest
PGBACKREST_STANZA=dotmac-sub
PGBACKREST_MAX_BACKUP_AGE_SECONDS=36000
PGBACKREST_BAO_SECRET_PATH=secret/backups/postgres
PGBACKREST_BAO_SECRET_FIELD=repo1_cipher_pass
PGBACKREST_RESTORE_VERIFY_ENABLED=true
PGBACKREST_VERIFY_DB_NAME=dotmac_sub
# Keep the existing off-host logical backup until a dedicated pgBackRest S3
# repository and an off-host restore drill are proven.
BACKUP_PRIMARY_POSTGRES_LOGICAL=true
# Fresh installs: generate this key once. Upgrades: keep the exact existing key;
# replacing it makes every existing enc: value undecryptable.
CREDENTIAL_ENCRYPTION_KEY=generate-with-make-generate-encryption-key
# One-time OpenBao bootstrap input. Set this to the exact same value as
# CREDENTIAL_ENCRYPTION_KEY, never a newly generated upgrade key. Remove it after
# scripts/setup/openbao_init.sh, then point CREDENTIAL_ENCRYPTION_KEY at the
# managed reference below for scheduled rotation.
# CREDENTIAL_ENCRYPTION_KEY=bao://secret/settings/auth#credential_encryption_key
CREDENTIAL_ENCRYPTION_KEY_SEED=
CREDENTIAL_ROTATION_ENABLED=true
CREDENTIAL_ROTATION_AUTO_APPLY=true
CREDENTIAL_ROTATION_INTERVAL_DAYS=90
CREDENTIAL_ROTATION_GRACE_DAYS=7

# Database pool limits are per process. The default is sized for the current
# production shape: 4 Uvicorn workers plus 10 Celery prefork children against a
# ~100-connection Postgres. Keep these conservative unless PgBouncer is in front
# of Postgres or max_connections has been deliberately resized.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT=20
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=120000
DB_LOCK_TIMEOUT_MS=10000
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=60000
WEB_THREADPOOL_LIMIT=6

# Shared Redis/cache
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis-host:6379/0
SESSION_REDIS_URL=redis://:change-me@redis-host:6379/0
CELERY_BROKER_URL=redis://:change-me@redis-host:6379/0
CELERY_RESULT_BACKEND=redis://:change-me@redis-host:6379/1

# Shared private S3-compatible object storage
S3_ENDPOINT_URL=http://s3-host:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET_NAME=dotmac-private
S3_REGION=us-east-1

# Migration scripts (SmartOLT + Splynx) — only needed during migration
# SMARTOLT_API_KEY=your-smartolt-api-key
# SPLYNX_MYSQL_PASS=your-splynx-mysql-password
# SPLYNX_MYSQL_PASSWORD=your-splynx-mysql-password
# GENIEACS_NBI_URL=http://localhost:7557

# Shared observability/secrets
GLITCHTIP_DSN=http://project-dsn@observability-host:8000/1
GLITCHTIP_ENABLED=true
OPENBAO_ADDR=http://observability-host:8200
OPENBAO_TOKEN=change-me
# Prefer a mounted token file over OPENBAO_TOKEN when the deployment supports it.
# OPENBAO_TOKEN_FILE=/run/secrets/openbao_token
OPENBAO_CACHE_TTL_SECONDS=60
LOKI_URL=http://observability-host:3100

# --- added 2026-04-16 — compose no longer provides defaults for these; fail-fast required ---
# FreeRADIUS SQL is intentionally separate from the app DATABASE_URL. On an
# upgrade, seed these from the existing active FreeRADIUS connector target.
FREERADIUS_DB_HOST=radius-db
FREERADIUS_DB_PORT=5432
FREERADIUS_DB_NAME=radius
FREERADIUS_DB_USER=radius
FREERADIUS_DB_PASS=change-me-generate-with-openssl-rand-base64-24
RADIUS_ACCOUNTING_SOURCE_STALE_SECONDS=3600
# Shared secret for the admin-login (device-login) RADIUS realm on 1822/1823.
# Must match each router's `/radius service=login` secret. Generate with openssl.
ADMIN_RADIUS_SECRET=change-me-generate-with-openssl-rand-hex-24
GENIEACS_MONGODB_PASSWORD=change-me-generate-with-openssl-rand-base64-24
GENIEACS_UI_JWT_SECRET=change-me-generate-with-openssl-rand-base64-24
TR069_AUTH_SHARED_SECRET=change-me-generate-with-openssl-rand-base64-32
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-generate-with-openssl-rand-base64-24
# Live chat (bridges to the CRM chat_widget channel). See docs/CHAT_LIVE_SETUP.md.
# Leave CHAT_LIVE_ENABLED off until the CRM side is deployed + seeded.
CHAT_LIVE_ENABLED=false
# ChatWidgetConfig UUID printed by the CRM seed script (scripts/seed_chat_widget.py).
CRM_CHAT_CONFIG_ID=
# Must equal the secret on the CRM webhook endpoint pointing at /webhooks/crm/chat.
CRM_CHAT_WEBHOOK_SECRET=change-me-generate-with-openssl-rand-base64-32
# Optional; defaults to wss://<CRM host>/ws/widget.
CRM_CHAT_WS_URL=

# Router config snapshots via SSH /export (RouterOS 7.x REST can't return config
# text). Uses the dedicated dotmac-ops SSH key (not the API/REST identity).
# Place the key on the host at ./secrets/dotmac-ops.key (mounted into celery-worker).
ROUTER_CONFIG_EXPORT_VIA_SSH=true
ROUTER_CONFIG_SSH_USERNAME=dotmac-ops
ROUTER_CONFIG_SSH_PORT=120
ROUTER_CONFIG_SSH_KEY_PATH=/etc/dotmac/dotmac-ops.key
ROUTER_CONFIG_SSH_KNOWN_HOSTS_PATH=/etc/dotmac/router_known_hosts
ROUTER_CONFIG_SSH_STRICT_HOST_KEY=false

# Synthetic RADIUS auth probe (radius_health). Unset = probe disabled.
# Generate: openssl rand -base64 24
RADIUS_PROBE_SECRET=
RADIUS_PROBE_PASSWORD=
# Worker source range FreeRADIUS accepts the probe from (compose bridge).
RADIUS_PROBE_CLIENT_SUBNET=172.20.0.0/16

# Subnet for the compose bridge the app/workers run on (docker-compose.yml).
# Leave unset unless this host runs more than one Dotmac stack: dotmac_crm's
# compose also claims 172.20.255.0/24, so co-hosting sub + CRM collides, and
# `docker compose up` will try to tear down and recreate the network -- which
# disconnects the DB (compose treats it as an orphan and does NOT reattach it)
# and any sibling stack's containers sharing the bridge.
#
# MUST stay inside RADIUS_PROBE_CLIENT_SUBNET above. Moving the containers out of
# that range does not error -- FreeRADIUS just silently stops accepting their
# probe requests.
#
#   DOCKER_SUBNET=172.20.254.0/24
