# Core database/runtime (Compose defaults to the local dotmac-db service)
APP_ENV=production
SERVER_NAME=dotmac-sub-prod
APP_URL=https://selfcare.dotmac.io
DATABASE_URL=postgresql+psycopg://postgres:change-me@dotmac-db:5432/dotmac_sub
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
POSTGRES_PASSWORD=change-me
CREDENTIAL_ENCRYPTION_KEY=generate-with-make-generate-encryption-key

# Shared Redis/cache
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis-host:6379/0
SESSION_REDIS_URL=redis://:change-me@redis-host:6379/0
CELERY_BROKER_URL=redis://:change-me@redis-host:6379/0
CELERY_RESULT_BACKEND=redis://:change-me@redis-host:6379/1

# Shared private S3-compatible object storage
S3_ENDPOINT_URL=http://s3-host:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET_NAME=dotmac-private
S3_REGION=us-east-1

# Migration scripts (SmartOLT + Splynx) — only needed during migration
# SMARTOLT_API_KEY=your-smartolt-api-key
# SPLYNX_MYSQL_PASS=your-splynx-mysql-password
# SPLYNX_MYSQL_PASSWORD=your-splynx-mysql-password
# GENIEACS_NBI_URL=http://localhost:7557

# Shared observability/secrets
GLITCHTIP_DSN=http://project-dsn@observability-host:8000/1
GLITCHTIP_ENABLED=true
OPENBAO_ADDR=http://observability-host:8200
OPENBAO_TOKEN=change-me
LOKI_URL=http://observability-host:3100

# --- added 2026-04-16 — compose no longer provides defaults for these; fail-fast required ---
RADIUS_DB_PASS=change-me-generate-with-openssl-rand-base64-24
# Shared secret for the admin-login (device-login) RADIUS realm on 1822/1823.
# Must match each router's `/radius service=login` secret. Generate with openssl.
ADMIN_RADIUS_SECRET=change-me-generate-with-openssl-rand-hex-24
GENIEACS_MONGODB_PASSWORD=change-me-generate-with-openssl-rand-base64-24
GENIEACS_UI_JWT_SECRET=change-me-generate-with-openssl-rand-base64-24
TR069_AUTH_SHARED_SECRET=change-me-generate-with-openssl-rand-base64-32
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-generate-with-openssl-rand-base64-24
# Live chat (bridges to the CRM chat_widget channel). See docs/CHAT_LIVE_SETUP.md.
# Leave CHAT_LIVE_ENABLED off until the CRM side is deployed + seeded.
CHAT_LIVE_ENABLED=false
# ChatWidgetConfig UUID printed by the CRM seed script (scripts/seed_chat_widget.py).
CRM_CHAT_CONFIG_ID=
# Must equal the secret on the CRM webhook endpoint pointing at /webhooks/crm/chat.
CRM_CHAT_WEBHOOK_SECRET=change-me-generate-with-openssl-rand-base64-32
# Optional; defaults to wss://<CRM host>/ws/widget.
CRM_CHAT_WS_URL=

# Router config snapshots via SSH /export (RouterOS 7.x REST can't return config
# text). Uses the dedicated dotmac-ops SSH key (not the API/REST identity).
# Place the key on the host at ./secrets/dotmac-ops.key (mounted into celery-worker).
ROUTER_CONFIG_EXPORT_VIA_SSH=true
ROUTER_CONFIG_SSH_USERNAME=dotmac-ops
ROUTER_CONFIG_SSH_PORT=120
ROUTER_CONFIG_SSH_KEY_PATH=/etc/dotmac/dotmac-ops.key
ROUTER_CONFIG_SSH_KNOWN_HOSTS_PATH=/etc/dotmac/router_known_hosts
ROUTER_CONFIG_SSH_STRICT_HOST_KEY=false
