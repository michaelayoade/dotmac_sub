# -*- text -*-
# FreeRADIUS default site configuration
# Handles authentication, authorization, and accounting

server default {
	listen {
		type = auth
		ipaddr = *
		port = 0
		# BlastRADIUS (CVE-2024-3596) mitigation — reject Access-Request
		# packets without a valid Message-Authenticator. Per-client overrides
		# live in the `nas` table's require_message_authenticator column.
		require_message_authenticator = yes
	}

	listen {
		type = acct
		ipaddr = *
		port = 0
	}

	authorize {
		filter_username
		preprocess
		# CHAP must run in authorize so it can set Auth-Type := CHAP
		# when CHAP-Password is present in the request.
		chap
		if (&MS-CHAP-Challenge && (&MS-CHAP-Response || &MS-CHAP2-Response)) {
			update control {
				Auth-Type := MS-CHAP
			}
		}
		suffix
		sql
		mschap
		pap
	}

	authenticate {
		Auth-Type PAP {
			pap
		}
		Auth-Type CHAP {
			chap
		}
		Auth-Type MS-CHAP {
			mschap
		}
	}

	preacct {
		preprocess
		acct_unique
		suffix
	}

	accounting {
		sql
	}

	# Simultaneous-Use enforcement uses simul_count_query / simul_verify_query
	# defined in mods-enabled/sql. Remove this block if Simultaneous-Use is
	# not set on any radcheck/radgroupcheck row — it costs one query per auth.
	session {
		sql
	}

	post-auth {
		sql
		Post-Auth-Type REJECT {
			sql
		}
	}
}
