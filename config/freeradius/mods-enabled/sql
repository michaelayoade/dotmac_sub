# -*- text -*-
# FreeRADIUS SQL module configuration
# PostgreSQL backend for user authentication and accounting

sql {
	dialect = "postgresql"
	driver = "rlm_sql_postgresql"

	# Connection parameters from environment variables
	server = "$ENV{FREERADIUS_DB_HOST}"
	port = $ENV{FREERADIUS_DB_PORT}
	login = "$ENV{FREERADIUS_DB_USER}"
	password = "$ENV{FREERADIUS_DB_PASS}"
	radius_db = "$ENV{FREERADIUS_DB_NAME}"

	# SQL username from RADIUS User-Name attribute
	sql_user_name = "%{User-Name}"

	# Restrict character set in interpolated values to prevent
	# SQL injection through usernames / station IDs. Any character
	# outside this set causes the module to return notfound.
	safe_characters = "@abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.-_: /"

	# Table configuration
	acct_table1 = "radacct"
	acct_table2 = "radacct"
	postauth_table = "radpostauth"
	authcheck_table = "radcheck"
	groupcheck_table = "radgroupcheck"
	authreply_table = "radreply"
	groupreply_table = "radgroupreply"
	usergroup_table = "radusergroup"

	# We rely on ON CONFLICT in the start query to handle Accounting-Start
	# retransmits; do not also let the module pre-delete open sessions.
	delete_stale_sessions = no

	# Read NAS clients from database
	read_clients = yes
	client_table = "nas"

	# Pool configuration
	pool {
		start = 10
		min = 5
		max = 30
		spare = 10
		uses = 0
		lifetime = 3600
		idle_timeout = 60
	}

	# Read NAS clients including BlastRADIUS mitigation flags.
	client_query = "\
		SELECT id, nasname, shortname, type, secret, server, community, description, \
		       require_message_authenticator, limit_proxy_state \
		FROM ${client_table}"

	# Group membership query
	group_membership_query = "\
		SELECT groupname \
		FROM ${usergroup_table} \
		WHERE username = '%{SQL-User-Name}' \
		ORDER BY priority"

	# Authorization queries
	authorize_check_query = "\
		SELECT id, username, attribute, value, op \
		FROM ${authcheck_table} \
		WHERE username = '%{SQL-User-Name}' \
		ORDER BY id"

	authorize_reply_query = "\
		SELECT id, username, attribute, value, op \
		FROM ${authreply_table} \
		WHERE username = '%{SQL-User-Name}' \
		ORDER BY id"

	authorize_group_check_query = "\
		SELECT id, groupname, attribute, value, op \
		FROM ${groupcheck_table} \
		WHERE groupname = '%{SQL-Group}' \
		ORDER BY id"

	authorize_group_reply_query = "\
		SELECT id, groupname, attribute, value, op \
		FROM ${groupreply_table} \
		WHERE groupname = '%{SQL-Group}' \
		ORDER BY id"

	# Simultaneous-Use enforcement (called from `session { sql }`).
	simul_count_query = "\
		SELECT COUNT(*) \
		FROM ${acct_table1} \
		WHERE username = '%{SQL-User-Name}' \
		  AND acctstoptime IS NULL"

	simul_verify_query = "\
		SELECT radacctid, acctsessionid, username, \
		       nasipaddress, nasportid, framedipaddress, \
		       callingstationid, framedprotocol \
		FROM ${acct_table1} \
		WHERE username = '%{SQL-User-Name}' \
		  AND acctstoptime IS NULL"

	accounting {
		reference = "%{tolower:type.%{%{Acct-Status-Type}:-%{Request-Processing-Stage}}.query}"

		type {
				accounting-on {
					query = "\
						UPDATE ${....acct_table1} \
						SET acctstoptime = NOW(), \
						    acctsessiontime = COALESCE(EXTRACT(EPOCH FROM (NOW() - acctstarttime))::integer, 0), \
						    acctterminatecause = 'NAS-Reboot' \
						WHERE acctstoptime IS NULL \
						  AND nasipaddress = '%{NAS-IP-Address}'"
			}

				accounting-off {
					query = "\
						UPDATE ${....acct_table1} \
						SET acctstoptime = NOW(), \
						    acctsessiontime = COALESCE(EXTRACT(EPOCH FROM (NOW() - acctstarttime))::integer, 0), \
						    acctterminatecause = 'NAS-Shutdown' \
						WHERE acctstoptime IS NULL \
						  AND nasipaddress = '%{NAS-IP-Address}'"
			}

				start {
					query = "\
						INSERT INTO ${....acct_table1} \
							(acctsessionid, acctuniqueid, username, nasipaddress, nasportid, nasporttype, \
						 acctstarttime, acctupdatetime, acctstoptime, acctsessiontime, acctauthentic, \
						 connectinfo_start, calledstationid, callingstationid, servicetype, framedprotocol, \
						 framedipaddress, framedipv6address, framedipv6prefix, framedinterfaceid, delegatedipv6prefix, class) \
					VALUES \
						('%{Acct-Session-Id}', '%{Acct-Unique-Session-Id}', '%{SQL-User-Name}', \
						 NULLIF('%{NAS-IP-Address}', '')::inet, '%{NAS-Port-ID}', '%{NAS-Port-Type}', \
						 NOW(), NOW(), NULL, 0, '%{Acct-Authentic}', \
						 '%{Connect-Info}', '%{Called-Station-Id}', '%{Calling-Station-Id}', '%{Service-Type}', \
						 '%{Framed-Protocol}', NULLIF('%{Framed-IP-Address}', '')::inet, '%{Framed-IPv6-Address}', \
						 '%{Framed-IPv6-Prefix}', '%{Framed-Interface-Id}', '%{Delegated-IPv6-Prefix}', \
						 '%{Class}') \
					ON CONFLICT (acctuniqueid) DO UPDATE \
					SET nasportid = EXCLUDED.nasportid, \
					    nasporttype = EXCLUDED.nasporttype, \
					    acctupdatetime = EXCLUDED.acctupdatetime, \
					    connectinfo_start = EXCLUDED.connectinfo_start, \
					    framedipaddress = EXCLUDED.framedipaddress, \
					    framedipv6address = EXCLUDED.framedipv6address, \
					    framedipv6prefix = EXCLUDED.framedipv6prefix, \
					    framedinterfaceid = EXCLUDED.framedinterfaceid, \
					    delegatedipv6prefix = EXCLUDED.delegatedipv6prefix \
					WHERE ${....acct_table1}.acctstoptime IS NULL"
			}

				interim-update {
					query = "\
						UPDATE ${....acct_table1} \
						SET acctupdatetime = NOW(), \
					    acctinterval = NULLIF('%{%{Acct-Interim-Interval}:-0}', '')::integer, \
					    acctsessiontime = NULLIF('%{%{Acct-Session-Time}:-0}', '')::bigint, \
					    acctinputoctets = ((COALESCE(NULLIF('%{%{Acct-Input-Gigawords}:-0}', ''), '0')::bigint << 32) + NULLIF('%{%{Acct-Input-Octets}:-0}', '')::bigint), \
					    acctoutputoctets = ((COALESCE(NULLIF('%{%{Acct-Output-Gigawords}:-0}', ''), '0')::bigint << 32) + NULLIF('%{%{Acct-Output-Octets}:-0}', '')::bigint), \
					    framedipaddress = NULLIF('%{Framed-IP-Address}', '')::inet, \
					    framedipv6address = '%{Framed-IPv6-Address}', \
					    framedipv6prefix = '%{Framed-IPv6-Prefix}', \
					    framedinterfaceid = '%{Framed-Interface-Id}', \
					    delegatedipv6prefix = '%{Delegated-IPv6-Prefix}', \
					    callingstationid = '%{Calling-Station-Id}' \
					WHERE acctuniqueid = '%{Acct-Unique-Session-Id}'"

				# Fallback INSERT if the Start packet was lost and this
				# Interim-Update arrived first. Backfills the row so the
				# stop event can later close it cleanly.
				query = "\
					INSERT INTO ${....acct_table1} \
						(acctsessionid, acctuniqueid, username, nasipaddress, nasportid, nasporttype, \
						 acctstarttime, acctupdatetime, acctsessiontime, acctinputoctets, acctoutputoctets, \
						 acctauthentic, calledstationid, callingstationid, servicetype, framedprotocol, \
						 framedipaddress, framedipv6address, framedipv6prefix, framedinterfaceid, delegatedipv6prefix, class) \
					VALUES \
						('%{Acct-Session-Id}', '%{Acct-Unique-Session-Id}', '%{SQL-User-Name}', \
						 NULLIF('%{NAS-IP-Address}', '')::inet, '%{NAS-Port-ID}', '%{NAS-Port-Type}', \
						 NOW() - '%{%{Acct-Session-Time}:-0} seconds'::interval, NOW(), \
						 NULLIF('%{%{Acct-Session-Time}:-0}', '')::bigint, \
						 ((COALESCE(NULLIF('%{%{Acct-Input-Gigawords}:-0}', ''), '0')::bigint << 32) + NULLIF('%{%{Acct-Input-Octets}:-0}', '')::bigint), \
						 ((COALESCE(NULLIF('%{%{Acct-Output-Gigawords}:-0}', ''), '0')::bigint << 32) + NULLIF('%{%{Acct-Output-Octets}:-0}', '')::bigint), \
						 '%{Acct-Authentic}', '%{Called-Station-Id}', '%{Calling-Station-Id}', \
						 '%{Service-Type}', '%{Framed-Protocol}', \
						 NULLIF('%{Framed-IP-Address}', '')::inet, '%{Framed-IPv6-Address}', \
						 '%{Framed-IPv6-Prefix}', '%{Framed-Interface-Id}', '%{Delegated-IPv6-Prefix}', \
						 '%{Class}') \
					ON CONFLICT (acctuniqueid) DO NOTHING"
			}

				stop {
					query = "\
						UPDATE ${....acct_table1} \
						SET acctstoptime = NOW(), \
					    acctsessiontime = NULLIF('%{%{Acct-Session-Time}:-0}', '')::bigint, \
					    acctinputoctets = ((COALESCE(NULLIF('%{%{Acct-Input-Gigawords}:-0}', ''), '0')::bigint << 32) + NULLIF('%{%{Acct-Input-Octets}:-0}', '')::bigint), \
					    acctoutputoctets = ((COALESCE(NULLIF('%{%{Acct-Output-Gigawords}:-0}', ''), '0')::bigint << 32) + NULLIF('%{%{Acct-Output-Octets}:-0}', '')::bigint), \
					    acctterminatecause = '%{Acct-Terminate-Cause}', \
					    connectinfo_stop = '%{Connect-Info}', \
					    framedipaddress = NULLIF('%{Framed-IP-Address}', '')::inet, \
					    framedipv6address = '%{Framed-IPv6-Address}', \
					    framedipv6prefix = '%{Framed-IPv6-Prefix}', \
					    framedinterfaceid = '%{Framed-Interface-Id}', \
					    delegatedipv6prefix = '%{Delegated-IPv6-Prefix}', \
					    callingstationid = '%{Calling-Station-Id}' \
					WHERE acctuniqueid = '%{Acct-Unique-Session-Id}'"

				# Fallback INSERT if Stop arrives without a prior Start.
				query = "\
					INSERT INTO ${....acct_table1} \
						(acctsessionid, acctuniqueid, username, nasipaddress, nasportid, nasporttype, \
						 acctstarttime, acctupdatetime, acctstoptime, acctsessiontime, acctinputoctets, \
						 acctoutputoctets, acctauthentic, connectinfo_stop, calledstationid, callingstationid, \
						 servicetype, framedprotocol, framedipaddress, framedipv6address, framedipv6prefix, \
						 framedinterfaceid, delegatedipv6prefix, acctterminatecause, class) \
					VALUES \
						('%{Acct-Session-Id}', '%{Acct-Unique-Session-Id}', '%{SQL-User-Name}', \
						 NULLIF('%{NAS-IP-Address}', '')::inet, '%{NAS-Port-ID}', '%{NAS-Port-Type}', \
						 NOW() - '%{%{Acct-Session-Time}:-0} seconds'::interval, NOW(), NOW(), \
						 NULLIF('%{%{Acct-Session-Time}:-0}', '')::bigint, \
						 ((COALESCE(NULLIF('%{%{Acct-Input-Gigawords}:-0}', ''), '0')::bigint << 32) + NULLIF('%{%{Acct-Input-Octets}:-0}', '')::bigint), \
						 ((COALESCE(NULLIF('%{%{Acct-Output-Gigawords}:-0}', ''), '0')::bigint << 32) + NULLIF('%{%{Acct-Output-Octets}:-0}', '')::bigint), \
						 '%{Acct-Authentic}', '%{Connect-Info}', '%{Called-Station-Id}', \
						 '%{Calling-Station-Id}', '%{Service-Type}', '%{Framed-Protocol}', \
						 NULLIF('%{Framed-IP-Address}', '')::inet, '%{Framed-IPv6-Address}', \
						 '%{Framed-IPv6-Prefix}', '%{Framed-Interface-Id}', '%{Delegated-IPv6-Prefix}', \
						 '%{Acct-Terminate-Cause}', '%{Class}') \
					ON CONFLICT (acctuniqueid) DO NOTHING"
			}
		}
	}

	# Post-auth runs on both Access-Accept and Access-Reject.
	# We log NAS + station context for forensics but never the password.
	post-auth {
		query = "\
			INSERT INTO ${..postauth_table} \
				(username, pass, reply, authdate, nasipaddress, calledstationid, callingstationid) \
			VALUES \
				('%{SQL-User-Name}', '', '%{reply:Packet-Type}', NOW(), \
				 NULLIF('%{NAS-IP-Address}', '')::inet, \
				 '%{Called-Station-Id}', '%{Calling-Station-Id}')"
	}
}
